{
  "expo": {
    "name": "NEXTTRP Vendor",
    "slug": "xyz-vendor-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vendor",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8631A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nexttrp.vendor"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8631A"
      },
      "package": "com.nexttrp.vendor"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NEXTTRP Vendor to access your photos for package images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
